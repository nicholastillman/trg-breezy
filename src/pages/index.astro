---
import Layout from "@layouts/Layout.astro";
import Panel from "@components/astro/Panel.astro";
import Header from "@components/astro/Header.astro";
import Hero from "@components/astro/Hero.astro";
import ClientLogos from "@components/astro/ClientLogos.astro";
import FeaturesGrid from "@components/astro/FeaturesGrid.astro";
import HowItWorks from "@components/astro/HowItWorks.astro";
import Newsletter from "@components/astro/Newsletter.astro";
import Footer from "@components/astro/Footer.astro";
// ────────────── Framework Components ──────────
import AtmosphereSync from "@components/vue/AtmosphereSync/AtmosphereSync.vue";
---

<Layout>
  <Header />
  <Hero />
  <ClientLogos />

  <FeaturesGrid />
  <HowItWorks />
  <!-- ── Atmosphere Sync — the Vue island ──────────────────────────────── -->
  <Panel id="atmosphere-sync" fullWidth>
    <AtmosphereSync :isVisible="showHistory" client:idle />
  </Panel>
  <Newsletter />
  <div class="entry-links"></div>
</Layout>

<Footer />

<style>
  :global(#atmosphere-sync):not(astro-island #atmosphere-sync) {
    border-bottom: 2px solid var(--color-palette-sky-50);
  }
</style>
