<!-- NEWSLETTER CTA -->
<section class="newsletter" id="signup">
  <h2>Ready to breathe different?</h2>
  <p>
    Join 12,847 breathers. Get weekly air quality insights and exclusive nostril
    tips.
  </p>
  <div class="nl-form">
    <input type="email" placeholder="you@breathe.io" id="emailInput" />
    <button class="button primary" onclick="handleSignup()"
      >Subscribe Free →</button
    >
  </div>
  <p style="font-size:0.75rem; color:var(--slate-500); margin-top:14px;">
    No spam. Just air. Unsubscribe by holding your breath for 60 seconds.
  </p>
</section>
<style>
  .newsletter {
    background: var(--color-palette-slate-900);
    border-radius: var(--radius-lg);
    color: var(--color-palette-sky-50);
    display: grid;
    gap: 1rem;
    place-content: center;
    max-inline-size: 720px;
    margin-inline: auto;
    margin-block: var(--space-2xl);
    padding: 3rem;
    text-align: center;

    .nl-form {
      display: grid;
      gap: 1rem;
      padding-inline: var(--space-lg);

      > * {
        border-radius: 50px;
        padding-block: var(--space-sm);
        padding-inline: var(--space-sm);
      }
      input[type="email"] {
        background: rgba(255, 255, 255, 0.08);
        border: 1.5px solid rgba(255, 255, 255, 0.15);
        font-size: 0.95rem;
      }
      button {
        background-color: var(--color-palette-sky-500);
        border: none;
        color: var(--color-light);
        text-align: left;
        transition: all 400ms ease-out;
        &.primary {
          background: var(--color-palette-sky-500);
          border: none;
          box-shadow: 0 4px 16px rgba(14, 165, 233, 0.35);
          color: var(--color-light);

          &:hover {
            background-color: var(--color-palette-sky-700);
            transform: translateY(-4px);
          }
        }
      }
    }
  }
