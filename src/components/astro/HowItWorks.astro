---
import Panel from "@components/astro/Panel.astro";
import Timeline from "@components/astro/TimeLine/Timeline.astro";
import Step from "@components/astro/TimeLine/Step.astro";
---

<Panel
  id="how"
  label="How It Works"
  heading="Three steps to better breathing"
  centered
  accent
>
  <Timeline>
    <Step
      step={1}
      heading="Take Our Quiz"
      bodyText="Answer 47 deeply personal questions so we can recommend the air you were already breathing."
    />
    <Step
      step={2}
      heading="We “Curate”"
      bodyText="Our team spends 0 minutes hand-selecting the exact same air from our warehouse (the sky)."
    />
    <Step
      step={3}
      heading="Breathe & Subscribe"
      bodyText="Inhale, exhale, repeat. If you stop, it’s not our fault but also please don’t cancel."
    />
  </Timeline>
</Panel>
