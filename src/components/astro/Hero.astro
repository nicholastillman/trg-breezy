      Premium <em class="accent">Artisanal Air,</em><br />
      Delivered Fresh
    </h1>

    <p class="sub">
      Hand-curated atmospheric blends sourced from the world's finest altitudes.
      Because you deserve air with character.
    </p>

    <div class="actions">
      <!-- Primary CTA -->
      <a href="/pricing" class="button primary">Start Breathing Better →</a>
      <!-- Secondary — note "Watch the Story" implies video. -->
      <!-- Implement with a lightweight modal, not an embedded player -->
      <button class="button btn-ghost">▶ Watch the Story</button>
    </div>

    <!-- Social proof: faces + count. Psychological trust pattern. -->
    <div class="proof">
      <div class="avatars" aria-hidden="true">
        <!-- Stack 4 avatar circles -->
        <span class="avatar" style="background:#fcd34d">🧑</span>
        <span class="avatar" style="background:#a5f3fc">👩</span>
        <span class="avatar" style="background:#c4b5fd">🧔</span>
        <span class="avatar" style="background:#fda4af">👱</span>
        <span class="avatar" style="background:#86efac">👩&zwj;🦰</span>
      </div>
      <p class="proof-text">
        <strong>12,847</strong> breathers joined this month
      </p>
    </div>
  </div>
</section>

