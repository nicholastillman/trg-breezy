    <div class="footer-grid grid" data-grid="auto">
      <div class="footer-brand">
        <div class="nav-brand">
          <em>Breezy</em>&thinsp;™
        </div>
        <p>
          Making the world's most abundant resource feel exclusive since 2026.
          Venture-backed. Carbon-confused.
        </p>
      </div>
      <div>
        <h4>Product</h4>
        <ul role="menu" class="list">
          <li><a href="#features">Features</a></li>
          <li><a href="#pricing">Pricing</a></li>
          <li><a href="#">API Docs</a></li>
          <li><a href="#">Changelog</a></li>
        </ul>
      </div>
      <div>
        <h4>Company</h4>
        <ul role="menu" class="list">
          <li><a href="#">About (It's Air)</a></li>
          <li><a href="#">Blog</a></li>
          <li><a href="#">Careers</a></li>
          <li><a href="#">Press Kit</a></li>
        </ul>
      </div>
      <div>
        <h4>Legal</h4>
        <ul>
          <li><a href="#">Privacy Policy</a></li>
          <li><a href="#">Terms of Service</a></li>
          <li><a href="#">Air EULA</a></li>
