---
import Panel from "@components/astro/Panel.astro";
---

<Panel
  label="WHY BREEZY"
  heading="Air, but make it ✨ premium ✨"
  sub=" We ruined a perfectly free resource by adding a subscription model.
You’re welcome."
>
  <section class="features" id="features">
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon" style="background:#dbeafe;">🏔️</div>
        <h3>Mountain-Sourced™</h3>
        <p>
          Each batch is harvested at peak altitude by our trained Air Sommeliers
          using proprietary glass jars.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="background:#fce7f3;">🧬</div>
        <h3>DNA-Matched Blends</h3>
        <p>
          Our AI analyzes your 23andMe data to craft a bespoke nitrogen-oxygen
          ratio. Patent pending.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="background:#d1fae5;">🌿</div>
        <h3>Carbon-Neutral Carbon</h3>
        <p>
          We offset our CO₂ by thinking really hard about trees. It&#8217;s
          basically the same thing.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="background:#fef3c7;">⚡</div>
        <h3>Instant Delivery</h3>
        <p>
          Our patented &#8220;Open a Window&#8221; technology ensures
          same-second delivery anywhere on Earth.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="background:#ede9fe;">🔬</div>
        <h3>Lab-Verified Purity</h3>
        <p>
          Every batch is tested by scientists who definitely exist and are not
          just our intern in a lab coat.
        </p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="background:#ffe4e6;">🤝</div>
        <h3>Community Breathing</h3>
        <p>
          Join our Discord of 50k+ breathers. Share tips, techniques, and which
          nostril you prefer.
        </p>
      </div>
    </div>
  </section>
</Panel>

<style>
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
    margin-top: 56px;
  }
  .feature-card {
    background: var(--color-palette-slate-50);
    border: 1px solid var(--color-palette-slate-100);
    border-radius: var(--radius-lg);
    padding: 36px 28px;
    transition:
      transform 0.25s,
      box-shadow 0.25s;
    cursor: default;
  }
  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .feature-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin-bottom: 20px;
  }
  .feature-card h3 {
    font-size: 1.25rem;
    margin-bottom: 8px;
    font-weight: 700;
  }
  .feature-card p {
    color: var(--slate-500);
    font-size: 0.95rem;
  }
</style>
